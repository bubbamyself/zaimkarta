generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OfferStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AffiliateNetwork {
  LEADS_SU
  LEADGID
  DIRECT
  OTHER
}

enum ApprovalTone {
  LOW
  MEDIUM
  HIGH
}

enum AdminRole {
  BOSS
  ADMIN
}

enum SeoPageStatus {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum SeoPageType {
  CATEGORY
  ARTICLE
  SERVICE
}

model Offer {
  id              String            @id @default(cuid())
  slug            String            @unique
  status          OfferStatus       @default(PAUSED)
  brandName       String
  legalName       String?
  logoText        String?
  logoUrl         String?
  officialSite    String?
  shortDescription String?
  badge           String?
  rating          Decimal?          @db.Decimal(3, 2)
  reviewsCount    Int               @default(0)
  minAmount       Int?
  maxAmount       Int?
  minTermDays     Int?
  maxTermDays     Int?
  dailyRateFrom   Decimal?          @db.Decimal(5, 2)
  dailyRateTo     Decimal?          @db.Decimal(5, 2)
  pskFrom         Decimal?          @db.Decimal(6, 2)
  pskTo           Decimal?          @db.Decimal(6, 2)
  approvalLabel   String?
  approvalTone    ApprovalTone      @default(MEDIUM)
  decisionTime    String?
  payoutMethods   String[]          @default([])
  repaymentMethods String[]         @default([])
  requirements    String[]          @default([])
  documents       String[]          @default([])
  advantages      String[]          @default([])
  warnings        String[]          @default([])
  legalDisclosure String?
  displayPriority Int               @default(100)
  conditionsCheckedAt DateTime?
  updatedByUserAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  affiliateOffers AffiliateOffer[]
  offerClicks     OfferClick[]
  seoPageOffers   SeoPageOffer[]
}

model AffiliateOffer {
  id                     String           @id @default(cuid())
  offerId                String
  network                AffiliateNetwork
  networkName            String?
  networkOfferId         String?
  targetAction           String?
  payoutAmount           Decimal?         @db.Decimal(10, 2)
  currency               String           @default("RUB")
  holdDays               Int?
  reconciliationPeriod   String?
  geoIncluded            String[]         @default([])
  geoExcluded            String[]         @default([])
  dailyCap               Int?
  monthlyCap             Int?
  allowedTrafficTypes    String[]         @default([])
  forbiddenTrafficTypes  String[]         @default([])
  trackingBaseUrl        String
  trackingParamsTemplate Json?
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  offer                  Offer            @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerClicks            OfferClick[]

  @@index([offerId])
  @@index([network])
  @@index([isActive])
}

model Lead {
  id               String         @id @default(cuid())
  leadId           String         @unique
  landingPageUrl   String?
  referrer         String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  utmTerm          String?
  userAgent        String?
  ipHash           String?
  firstSeenAt      DateTime       @default(now())
  lastSeenAt       DateTime       @updatedAt
  createdAt        DateTime       @default(now())

  offerClicks      OfferClick[]

  @@index([createdAt])
  @@index([leadId])
}

model OfferClick {
  id               String          @id @default(cuid())
  leadId           String
  offerId          String
  affiliateOfferId String?
  pageUrl          String?
  pageType         String?
  categorySlug     String?
  cardPosition     Int?
  redirectUrl      String
  createdAt        DateTime        @default(now())

  lead             Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  offer            Offer           @relation(fields: [offerId], references: [id], onDelete: Cascade)
  affiliateOffer   AffiliateOffer? @relation(fields: [affiliateOfferId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([offerId])
  @@index([affiliateOfferId])
  @@index([createdAt])
  @@index([categorySlug])
}

model AdminUser {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  role         AdminRole  @default(ADMIN)
  permissions  String[]   @default([])
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([role])
  @@index([isActive])
}

model SeoPage {
  id              String           @id @default(cuid())
  slug            String           @unique
  status          SeoPageStatus    @default(DRAFT)
  pageType        SeoPageType      @default(CATEGORY)
  title           String
  description     String
  h1              String
  intro           String?
  content         String?
  riskNotice      String?
  editorNote      String?
  publishedAt     DateTime?
  updatedByUserAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  offers          SeoPageOffer[]
  faqItems        SeoPageFaqItem[]

  @@index([status])
  @@index([pageType])
}

model SeoPageOffer {
  id        String   @id @default(cuid())
  seoPageId String
  offerId   String
  position  Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seoPage   SeoPage  @relation(fields: [seoPageId], references: [id], onDelete: Cascade)
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([seoPageId, offerId])
  @@index([seoPageId, position])
  @@index([offerId])
}

model SeoPageFaqItem {
  id        String   @id @default(cuid())
  seoPageId String
  question  String
  answer    String
  position  Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seoPage   SeoPage  @relation(fields: [seoPageId], references: [id], onDelete: Cascade)

  @@index([seoPageId, position])
}
