# Скопируйте этот файл в deploy/production.env.server только на VPS.
# production.env.server закрыт .gitignore. Заглушки нельзя использовать при запуске.

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://zaimkarta.ru

POSTGRES_USER=zaimkarta
POSTGRES_DB=zaimkarta
POSTGRES_PASSWORD=replace-with-strong-random-password
# Имя db — внутреннее имя контейнера PostgreSQL, а не публичный адрес.
DATABASE_URL=postgresql://zaimkarta:replace-with-strong-random-password@db:5432/zaimkarta?schema=public

ADMIN_SESSION_SECRET=replace-with-strong-random-secret
LEAD_IP_HASH_SALT=replace-with-another-strong-random-secret

# Beget mailbox. Copy the real password from the password manager only on VPS.
ZAIMKARTA_MAIL_USER=zabota@zaimkarta.ru
ZAIMKARTA_MAIL_PASSWORD=replace-with-mailbox-password
ZAIMKARTA_MAIL_FROM_NAME=Забота ZaimKarta
ZAIMKARTA_MAIL_IMAP_HOST=imap.beget.com
ZAIMKARTA_MAIL_IMAP_PORT=993
ZAIMKARTA_MAIL_SMTP_HOST=smtp.beget.com
ZAIMKARTA_MAIL_SMTP_PORT=465
